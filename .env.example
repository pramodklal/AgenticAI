AZURE_OPENAI_ENDPOINT=https://<your-openai-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-azure-openai-api-key>
AZURE_OPENAI_DEPLOYMENT=<your-model-deployment-name>
AZURE_OPENAI_API_VERSION=2024-10-21

COSMOS_ENDPOINT=https://<your-cosmos-account>.documents.azure.com:443/
COSMOS_DATABASE_NAME=healthcoach
COSMOS_STATE_CONTAINER=conversation_state
COSMOS_USER_CONTAINER=user_profiles
COSMOS_WORKOUT_CONTAINER=workout_logs

AZURE_SEARCH_ENDPOINT=https://<your-search-service>.search.windows.net
AZURE_SEARCH_API_KEY=<your-azure-search-api-key>
AZURE_SEARCH_WELLNESS_INDEX=wellness-index
AZURE_SEARCH_NUTRITION_INDEX=nutrition-index

AZURE_STORAGE_CONNECTION_STRING=<your-azure-storage-connection-string>
AZURE_FILE_SHARE_NAME=wellness-docs

APPLICATIONINSIGHTS_CONNECTION_STRING=<your-appinsights-connection-string>
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=<your-langsmith-api-key>
LANGSMITH_PROJECT=myhealthcoach
